# DeepSeek-compatible chat completion settings.
# Copy to .env and fill the key locally. Do not commit real secrets.
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com
RESTATER_MODEL=deepseek-v4-pro

# Default project path for `restater check` when no path is passed.
RESTATER_DEFAULT_PROJECT_PATH=E:\your\default\project\path

# Optional runtime tuning.
RESTATER_TEMPERATURE=0.2
RESTATER_MAX_TOKENS=4096
RESTATER_CONTEXT_FILE_LIMIT=300
RESTATER_TEXT_READ_LIMIT=20000
RESTATER_PDF_PAGE_LIMIT=6
